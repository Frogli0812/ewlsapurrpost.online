{
  "name": "cat-booking-frontend",
  "version": "1.0.0",
  "description": "WLSA PurrPost 豆花喵语栈 - 撸猫社团预约系统前端",
  "main": "public/index.html",
  "scripts": {
    "start": "http-server public -p 8080 -c-1",
    "dev": "http-server public -p 8080 -c-1 -o",
    "build": "node scripts/build.js",
    "lint": "eslint src/js/**/*.js",
    "lint:fix": "eslint src/js/**/*.js --fix",
    "format": "prettier --write \"src/**/*.{js,css,html}\"",
    "validate": "node scripts/validate.js",
    "serve-docs": "swagger-ui-serve docs/api-spec.yaml",
    "test": "jest",
    "clean": "rimraf dist",
    "copy-assets": "cpx \"src/assets/**/*\" dist/assets && cpx \"src/css/**/*\" dist/css && cpx \"src/js/**/*\" dist/js",
    "minify": "node scripts/minify.js",
    "deploy": "npm run build && npm run validate",
    "docker:build": "docker build -f docker/Dockerfile -t cat-booking-frontend .",
    "docker:run": "docker run -d -p 8080:80 --name cat-booking-frontend cat-booking-frontend",
    "docker:stop": "docker stop cat-booking-frontend && docker rm cat-booking-frontend",
    "docker:compose": "docker-compose up -d",
    "docker:compose:down": "docker-compose down"
  },
  "keywords": [
    "cat",
    "booking",
    "frontend",
    "javascript",
    "html",
    "css",
    "spa"
  ],
  "author": "WLSA PurrPost Team",
  "license": "MIT",
  "devDependencies": {
    "@eslint/js": "^9.0.0",
    "cpx": "^1.5.0",
    "cssnano": "^6.0.0",
    "eslint": "^9.0.0",
    "html-minifier": "^4.0.0",
    "http-server": "^14.1.1",
    "jest": "^29.0.0",
    "postcss": "^8.0.0",
    "prettier": "^3.0.0",
    "rimraf": "^5.0.0",
    "swagger-ui-serve": "^3.0.0",
    "terser": "^5.0.0"
  },
  "dependencies": {},
  "browserslist": [
    "> 1%",
    "last 2 versions",
    "not dead"
  ],
  "engines": {
    "node": ">=16.0.0",
    "npm": ">=7.0.0"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/wlsa-purrpost/cat-booking-frontend.git"
  },
  "bugs": {
    "url": "https://github.com/wlsa-purrpost/cat-booking-frontend/issues"
  },
  "homepage": "https://wlsa-purrpost.com"
}
